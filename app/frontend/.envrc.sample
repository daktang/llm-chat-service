# ============================================
# LLM Chat Service - Central Configuration
# ============================================
# 이 파일을 .envrc로 복사한 뒤 환경에 맞게 값을 수정하세요.
#   cp .envrc.sample .envrc
#   direnv allow  (또는 source .envrc)
#
# ⚠️  VITE_LITELLM_BASE_URL, VITE_LITELLM_API_KEY는 필수입니다.
#     설정하지 않으면 서버가 시작되지 않습니다.
# ============================================

# --- LiteLLM API Configuration (필수) ---
# LiteLLM 프록시 서버 주소 (예: https://openllm.your-domain.net)
export VITE_LITELLM_BASE_URL=""

# LiteLLM API 인증 키
export VITE_LITELLM_API_KEY=""

# --- Vite Dev Server ---
# 로컬 개발 서버 포트 (기본: 3000)
export VITE_PORT="3000"