# ============================================
# LLM Chat Service - Central Configuration
# ============================================
# ⚠️  VITE_LITELLM_BASE_URL, VITE_LITELLM_API_KEY는 필수입니다.
#     설정하지 않으면 서버가 시작되지 않습니다.
# ============================================

# --- LiteLLM API Configuration (필수) ---
export VITE_LITELLM_BASE_URL="https://openllm.domain.net"
export VITE_LITELLM_API_KEY="your-api-key-here"

# --- Vite Dev Server ---
export VITE_PORT="3000"

# --- Docker / Kubernetes Configuration ---
export IMAGE_REPOSITORY="domain.net/docker.io/library/llm-chat-service"
export IMAGE_TAG="latest"
export K8S_NAMESPACE="default"
export REPLICA_COUNT="1"