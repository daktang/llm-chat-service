# ============================================
# LLM Chat Service - Central Configuration
# ============================================
# 이 파일에서 모든 서비스 설정을 관리합니다.
# 변경 후 `source .envrc` 또는 direnv를 사용하세요.
# ============================================

# --- Service Configuration ---
# 서비스가 바인딩될 호스트 (Istio Gateway/VirtualService에서 사용)
export SERVICE_HOST="llm-chat.internal.example.com"

# 서비스 포트 (컨테이너 및 K8s Service 포트, 항상 8080 고정)
export SERVICE_PORT="8080"

# --- LiteLLM API Configuration ---
# LiteLLM 프록시 서버 주소
export VITE_LITELLM_BASE_URL="https://openllm.net"

# LiteLLM API 인증 키
export VITE_LITELLM_API_KEY="your-api-key-here"

# --- Kubernetes / Helm Configuration ---
# Docker 이미지 레포지토리
export IMAGE_REPOSITORY="llm-chat-service"

# Docker 이미지 태그
export IMAGE_TAG="latest"

# K8s 네임스페이스
export K8S_NAMESPACE="default"

# Istio Gateway 이름 (이미 존재하는 공유 게이트웨이가 있다면 해당 이름 사용)
export ISTIO_GATEWAY_NAME="llm-chat-gateway"

# Replica 수
export REPLICA_COUNT="1"